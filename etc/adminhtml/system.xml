<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
	<system>
		<tab id="squadkin" translate="label" sortOrder="999">
			<label>Squadkin</label>
		</tab>
		<section id="squadexaiproductcreator" sortOrder="10" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
			<label>SquadexaAI Configuration</label>
			<tab>squadkin</tab>
			<resource>Squadkin_SquadexaAI::config_squadkin_squadexaai</resource>
			<group id="general" sortOrder="10" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
				<label>General Settings</label>
				<field id="is_enable" type="select" sortOrder="10" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
					<label>Is Enabled</label>
					<comment>Enable or disable SquadexaAI module</comment>
					<source_model>Magento\Config\Model\Config\Source\Enabledisable</source_model>
				</field>
			</group>
        <group id="authentication" sortOrder="20" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
            <label>🔐 Authentication Settings</label>
            <comment><![CDATA[<strong>How to setup API Authentication:</strong><br/>
            1. Create a free account at <a href="https://www.squadexa.ai/" target="_blank">Squadexa AI</a><br/>
            2. Enter your email and password below<br/>
            3. Click "Generate API Key" to create a permanent <code>pk_...</code> format API key<br/>
            4. Your API key will be saved securely and used for all product generation requests<br/>
            5. Monitor your credit balance in the dashboard<br/>
            <br/>
            <strong>Note:</strong> The API key format is always <code>pk_</code> followed by a secure token. It never expires and is used for billing by credit wallet.]]></comment>
            
            <field id="username" type="text" sortOrder="10" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
                <label>📧 Email</label>
                <comment>Your Squadexa AI account email</comment>
                <depends>
                    <field id="is_enable">1</field>
                </depends>
            </field>
            
            <field id="password" type="obscure" sortOrder="20" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
                <label>🔑 Password</label>
                <comment>Your Squadexa AI account password</comment>
                <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                <depends>
                    <field id="is_enable">1</field>
                </depends>
            </field>
            
            <field id="generate_token" type="button" sortOrder="30" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
                <label>🚀 Generate API Key</label>
                <comment><![CDATA[<strong>Click this button to generate your API Key automatically!</strong><br/>
                <br/>
                The system will:<br/>
                • Securely login with your credentials<br/>
                • Generate a permanent API Key<br/>
                • Save it automatically for immediate use<br/>
                <br/>
                Your API Key never expires and is used for all product generation requests.]]></comment>
                <frontend_model>Squadkin\SquadexaAI\Block\Adminhtml\System\Config\GenerateTokenButton</frontend_model>
                <depends>
                    <field id="is_enable">1</field>
                </depends>
            </field>
            
            <field id="api_key" type="obscure" sortOrder="40" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
                <label>🔐 API Key</label>
                <comment>Your permanent API key in format <code>pk_...</code> - automatically generated when you click "Generate API Key" button above. Never expires and is billed using wallet credits.</comment>
                <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                <depends>
                    <field id="is_enable">1</field>
                </depends>
            </field>
            
            <field id="api_key_status" type="note" sortOrder="50" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
                <label>📊 API Key Status</label>
                <comment>API key information and usage statistics</comment>
                <frontend_model>Squadkin\SquadexaAI\Block\Adminhtml\System\Config\TokenStatus</frontend_model>
                <depends>
                    <field id="is_enable">1</field>
                </depends>
            </field>
        </group>
        <group id="field_mapping" sortOrder="30" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
            <label>Field Mapping Configuration</label>
            <comment><![CDATA[Configure how AI-generated fields map to Magento product attributes.<br/>
            <strong>Instructions:</strong><br/>
            1. Select a Magento product attribute for each AI-generated field<br/>
            2. Each AI field can be mapped to only one Magento attribute<br/>
            3. Click "Test" button to verify a specific mapping<br/>
            4. Click "Save Mapping" to save your configuration<br/>
            5. Click "Save Config" at the top to apply changes<br/>
            <br/>
            <strong>Supported Attribute Types:</strong> Text, Textarea, Dropdown, Multiselect, Price]]></comment>
            <field id="default_mapping_rules" type="text" sortOrder="10" showInWebsite="0" showInStore="0" showInDefault="1" translate="label">
                <label>AI Field to Magento Attribute Mapping</label>
                <comment>Map AI-generated fields to Magento product attributes. This mapping will be used when creating products from AI data.</comment>
                <frontend_model>Squadkin\SquadexaAI\Block\Adminhtml\System\Config\FieldMapping</frontend_model>
                <depends>
                    <field id="is_enable">1</field>
                </depends>
            </field>
        </group>
	</section>
</system>
</config>