<script>
require(['jquery'], function($) {
    $(document).ready(function() {
        // Add full width class to Squadexa AI configuration section
        $('.section-config').each(function() {
            if ($(this).find('#squadexaiproductcreator_general').length > 0) {
                $(this).addClass('squadexa-fullwidth-section');
            }
        });

        // Ensure full width for Squadexa AI specific elements
        var selectors = [
            '#squadexaiproductcreator_general',
            '#squadexaiproductcreator_authentication',
            '#squadexaiproductcreator_account_status'
        ];
        $(selectors.join(', ')).each(function() {
            $(this).closest('.section-config').addClass('squadexa-fullwidth-section');
        });
    });
});
</script>
