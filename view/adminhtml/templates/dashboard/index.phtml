$apiKey = $block->getApiKey();
$data = $block->getDashboardData();
$usageStats = $data['usage_stats'] ?? [];
$creditsRemaining = (int)($usageStats['credits_remaining'] ?? 0);
$creditsUsed = (int)($usageStats['credits_used'] ?? 0);
$creditsTotal = $creditsRemaining + $creditsUsed;
$usagePercentage = ($creditsTotal > 0) ? ($creditsUsed / $creditsTotal) * 100 : 0;
$userEmail = $usageStats['user_email'] ?? '';
$currentPlan = $usageStats['plan_info']['current_plan'] ?? 'standard';
$chartData = $data['monthly_chart_data'] ?? [];
$activities = $data['recent_activities'] ?? [];

// Get SVG icons from provider
$iconProvider = \Magento\Framework\App\ObjectManager::getInstance()
    ->get(\Squadkin\SquadexaAI\Model\DashboardIconsProvider::class);
$iconsJson = $iconProvider->getIconsJson();
