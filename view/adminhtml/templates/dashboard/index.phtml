<script>
require(['jquery'], function($) {
    window.activityPagination = {
        totalPages: <?= $escaper->escapeJs($totalPages ?? 1) ?>,
        totalItems: <?= $escaper->escapeJs($totalItems ?? 0) ?>,
        perPage: 10,
        currentPage: 1,
        activityUrl: '<?= $escaper->escapeUrl($block->getUrl('squadkin_squadexaai/dashboard/activity')) ?>'
    };
    
    window.loadActivityPage = function(page) {
        if (page < 1 || page > window.activityPagination.totalPages) {
            return;
        }
        
        // Show loading state
        const container = document.getElementById('activity-list-container');
        const pagination = document.getElementById('activity-pagination');
        container.innerHTML = '<div class="activity-loading"><?= $escaper->escapeJs(__('Loading...')) ?></div>';
        
        // Disable pagination buttons
        const buttons = pagination.querySelectorAll('button');
        buttons.forEach(btn => btn.disabled = true);
        
        // Make AJAX request
        $.ajax({
            url: window.activityPagination.activityUrl,
            type: 'GET',
            data: { page: page },
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    // Update activities
                    let html = '';
                    response.activities.forEach(function(activity) {
                        html += '<div class="activity-item">' +
                            '<div class="activity-icon">' + (activity.success ? '🟢' : '🔴') + '</div>' +
                            '<div class="activity-details">' +
                            '<div class="activity-title">' + activity.tool_name + '</div>' +
                            '<div class="activity-type"><?= $escaper->escapeJs(__('Endpoint:')) ?> ' + 
                            activity.endpoint + '</div>' +
                            '</div>' +
                            '<div class="activity-meta">' +
                            '<div class="activity-words">' + parseInt(activity.total_words).toLocaleString() + 
                            ' <?= $escaper->escapeJs(__('words')) ?></div>' +
                            '<div class="activity-time">' + activity.timestamp + '</div>' +
                            '<div class="activity-processing"><?= $escaper->escapeJs(__('Processing:')) ?> ' + 
                            activity.processing_time + '</div>' +
                            '</div>' +
                            '</div>';
                    });
                    container.innerHTML = html;
                    
                    // Update pagination
                    updatePagination(response.pagination);
                    
                    // Update current page
                    window.activityPagination.currentPage = page;
                } else {
                    container.innerHTML = '<div class="activity-error">' + (response.message || 
                        '<?= $escaper->escapeJs(__('Error loading activities')) ?>') + '</div>';
                }
            },
            error: function() {
                container.innerHTML = '<div class="activity-error"><?= $escaper->escapeJs(
                    __('Error loading activities. Please try again.')
                ) ?></div>';
            },
            complete: function() {
                // Re-enable pagination buttons
                buttons.forEach(function(btn) { btn.disabled = false; });
            }
        });
    };
    
    function updatePagination(pagination) {
        const currentPageEl = document.getElementById('current-page');
        const totalPagesEl = document.getElementById('total-pages');
        const prevBtn = document.getElementById('prev-page');
        const nextBtn = document.getElementById('next-page');
        const numbersContainer = document.getElementById('pagination-numbers');
        
        if (currentPageEl) currentPageEl.textContent = pagination.current_page;
        if (totalPagesEl) totalPagesEl.textContent = pagination.total_pages;
        if (prevBtn) prevBtn.disabled = !pagination.has_prev;
        if (nextBtn) nextBtn.disabled = !pagination.has_next;
        
        // Update page numbers
        if (numbersContainer) {
            let html = '';
            const currentPage = pagination.current_page;
            const totalPages = pagination.total_pages;
            const startPage = Math.max(1, currentPage - 2);
            const endPage = Math.min(totalPages, currentPage + 2);
            
            if (startPage > 1) {
                html += '<button class="pagination-number" onclick="loadActivityPage(1)">1</button>';
                if (startPage > 2) {
                    html += '<span class="pagination-ellipsis">...</span>';
                }
            }
            
            for (let i = startPage; i <= endPage; i++) {
                html += '<button class="pagination-number ' + 
                    (i === currentPage ? 'active' : '') + 
                    '" onclick="loadActivityPage(' + i + ')">' + i + '</button>';
            }
            
            if (endPage < totalPages) {
                if (endPage < totalPages - 1) {
                    html += '<span class="pagination-ellipsis">...</span>';
                }
                html += '<button class="pagination-number" onclick="loadActivityPage(' + 
                    totalPages + ')">' + totalPages + '</button>';
            }
            
            numbersContainer.innerHTML = html;
        }
        
        // Update pagination info
        const startItem = ((pagination.current_page - 1) * pagination.per_page) + 1;
        const endItem = Math.min(pagination.current_page * pagination.per_page, pagination.total_items);
        const infoText = document.querySelector('.pagination-items');
        if (infoText) {
            infoText.textContent = '(<?= $escaper->escapeJs(__('Showing')) ?> ' + startItem + '-' + 
                endItem + ' <?= $escaper->escapeJs(__('of')) ?> ' + pagination.total_items + ')';
        }
    }
});

function copyApiKey() {
    const apiKey = '<?= $escaper->escapeJs($apiKey) ?>';
    navigator.clipboard.writeText(apiKey).then(function() {
        const button = event.target;
        button.textContent = '✓ <?= $escaper->escapeJs(__('Copied')) ?>';
        setTimeout(function() {
            button.textContent = '📋 <?= $escaper->escapeJs(__('Copy')) ?>';
        }, 2000);
    });
}
